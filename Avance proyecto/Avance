<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Brazza y Fogo – SLP</title>

  <!-- Importa las fuentes -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

  <style>

    
    :root {
      --gold: #c9a84c;       
      --dark: #111111;      
      --mid: #1c1c1c;        
      --cream: #f0ece4;       
    }


    * { margin: 0; padding: 0; box-sizing: border-box; }


    body {
      background-color: var(--dark);
      color: var(--cream);
      font-family: 'Lato', sans-serif;
    }


    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 60px;
      background: var(--dark);
      border-bottom: 1px solid var(--gold);
      position: sticky; 
      top: 0;
      z-index: 100;
    }


    nav .logo-wrap {
      display: flex;
      align-items: center;
      gap: 14px;
    }


    nav .logo-wrap img {
      width: 54px;
      height: 54px;
      object-fit: contain;
    }


    nav .brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      color: var(--gold);
      line-height: 1.1;
    }

   
    nav .brand span {
      display: block;
      font-size: 0.75rem;
      letter-spacing: 3px;
      color: var(--cream);
      font-family: 'Lato', sans-serif;
      font-weight: 300;
      text-transform: uppercase;
    }

   
    .hero {
      position: relative;
      height: 92vh; 
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      background: var(--dark);
    }

   
    .hero-content {
      position: relative;
    }

    .hero-logo {
      width: 120px;
      height: 120px;
      margin: 0 auto 28px;
    }


    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 7vw, 6rem); 
      font-weight: 900;
      line-height: 1;
      color: var(--cream);
      letter-spacing: 4px;
    }

    .hero h1 span {
      color: var(--gold);
    }

 
    .hero .tagline {
      font-size: 0.85rem;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: var(--gold);
      margin: 20px 0 40px;
      font-weight: 300;
    }

    .btn {
      display: inline-block;
      padding: 14px 40px;
      border: 1px solid var(--gold);
      color: var(--gold);
      text-decoration: none;
      font-size: 0.8rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      transition: all 0.3s;
      font-family: 'Lato', sans-serif;
    }


    .btn:hover {
      background: var(--gold);
      color: var(--dark);
    }

 
    section { padding: 90px 60px; }


    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.4rem;
      color: var(--gold);
      text-align: center;
      margin-bottom: 10px;
    }


    .section-line {
      width: 60px;
      height: 2px;
      background: var(--gold);
      margin: 0 auto 50px;
    }

    #menu { background: var(--mid); }

    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .menu-card {
      position: relative;
      overflow: hidden;
      aspect-ratio: 3/4;
      cursor: pointer;
    }

    .menu-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s;
    }

    .menu-card:hover img {
      transform: scale(1.04);
    }

    #galeria { background: var(--dark); }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .gallery-grid img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      transition: opacity 0.3s;
    }

    
    .gallery-grid img:hover {
      opacity: 0.8;
    }


    .gallery-grid img:nth-child(1) { grid-column: span 2; height: 320px; }
    .gallery-grid img:nth-child(5) { grid-column: span 2; height: 320px; }

  /*diseño responsivo celular */
    @media (max-width: 900px) {
      nav { padding: 14px 24px; }
      nav ul { gap: 18px; }
      section { padding: 60px 24px; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .gallery-grid img:nth-child(1),
      .gallery-grid img:nth-child(5) { grid-column: span 2; }
    }

    @media (max-width: 600px) {
      nav ul { display: none; }
      .hero h1 { font-size: 2.8rem; }
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .menu-grid { grid-template-columns: 1fr; }
    }

  </style>
</head>
<body>

 
  <nav>
    <div class="logo-wrap">
      <img src="logo_brazza.svg" alt="Logo Brazza y Fogo">
      <div class="brand">
        Brazza y Fogo
        <span>San Luis Potosí</span>
      </div>
    </div>
    <ul>
      <li><a href="#">Nosotros</a></li>
      <li><a href="#">Menú</a></li>
      <li><a href="#">Galería</a></li>
      <li><a href="#">Contacto</a></li>
    </ul>
  </nav>
  <section class="hero" id="inicio">
    <div class="hero-content">
      <img src="logo_brazza.svg" alt="Brazza y Fogo" class="hero-logo">
      <h1>BRAZZA <span>&</span> FOGO</h1>
      <p class="tagline">Churrasqueria · San Luis Potosí</p>
      <a href="#" class="btn">Ver Menú</a>
    </div>
  </section>

  <section id="menu">
    <h2 class="section-title">Nuestros Cortes</h2>
    <div class="section-line"></div>
    <div class="menu-grid">

   
      <div class="menu-card">
        <img src="Screenshot_60.png" alt="Costillas BBQ">
      </div>

   
      <div class="menu-card">
        <img src="Screenshot_59.png" alt="Picanha">
      </div>


      <div class="menu-card">
        <img src="Screenshot_58.png" alt="Costilla con Piña">
      </div>

      <div class="menu-card">
        <img src="Screenshot_57.png" alt="Piña Brazza">
      </div>


      <div class="menu-card">
        <img src="Screenshot_55.png" alt="Costillas">
      </div>


      <div class="menu-card">
        <img src="Screenshot_52.png" alt="">
      </div>

      <div class="menu-card">
        <img src="Screenshot_51.png" alt="">
      </div>

      <div class="menu-card">
        <img src="Screenshot_50.png" alt="">
      </div>

    </div>
  </section>


  <section id="galeria">
    <h2 class="section-title">Galería</h2>
    <div class="section-line"></div>
    <div class="gallery-grid">
      <img src="Screenshot_60.png" alt="galeria 1"> 
      <img src="Screenshot_54.png" alt="galeria 2">
      <img src="Screenshot_56.png" alt="galeria 3">
      <img src="Screenshot_49.png" alt="galeria 4">
      <img src="Screenshot_53.png" alt="galeria 5"> 
      <img src="Screenshot_51.png" alt="galeria 6">
      <img src="Screenshot_58.png" alt="galeria 7">
      <img src="Screenshot_52.png" alt="galeria 8">
    </div>
  </section>

</body>
</html>
